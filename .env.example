# Ask Liquid Data — environment variables
# Copy to .env for local use, or set these in the Railway service dashboard.

# ── LLM provider ──────────────────────────────────────────────────────────────
# Options: openrouter (production) | groq (rate-limited cloud) | claude_cli (local only)
LLM_PROVIDER=openrouter

# ── OpenRouter (production default — free tier) ───────────────────────────────
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
# OPENROUTER_MODEL=openrouter/auto          # auto-route to best available
# OPENROUTER_MODEL=google/gemma-3-27b-it:free
OPENROUTER_MAX_TOKENS=4096

# ── Groq (fallback) ──────────────────────────────────────────────────────────
# GROQ_API_KEY=gsk_...
# GROQ_MODEL=llama-3.3-70b-versatile

# ── Claude CLI (local dev only) ───────────────────────────────────────────────
# CLAUDE_CLI_TIMEOUT=300
